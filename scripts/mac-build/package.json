{
  "name": "gatewayedit-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electronite .",
    "dist:mac-arm64": "electronite-packager . \"$npm_package_build_productName\" --platform=darwin --arch=arm64 --overwrite --out=out --app-bundle-id=\"$npm_package_build_appId\" --name=\"$npm_package_build_productName\" --icon=./assets/icon.icns",
    "dist:mac-x64": "electronite-packager . \"$npm_package_build_productName\" --platform=darwin --arch=x64 --overwrite --out=out --app-bundle-id=\"$npm_package_build_appId\" --name=\"$npm_package_build_productName\" --icon=./assets/icon.icns",
    "dmg:mac-arm64": "electron-builder --arm64 --mac dmg --prepackaged out/$npm_package_build_productName-darwin-arm64",
    "dmg:mac-x64": "electron-builder --x64 --mac dmg --prepackaged out/$npm_package_build_productName-darwin-x64"
  },
  "dependencies": {},
  "devDependencies": {
    "electronite": "25.3.2-graphite",
    "electron": "25.3.2",
    "electronite-packager": "17.1.1-graphite",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "productName": "GatewayEdit",
    "appId": "com.example.gatewayedit",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "title": "GatewayEdit",
      "icon": "assets/icon.icns"
    }
  }
}
