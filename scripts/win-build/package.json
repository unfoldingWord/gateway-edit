{
  "name": "gatewayedit-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electronite .",
    "dist:win-x64": "electronite-packager . \"$npm_package_build_productName\" --platform=win32 --arch=x64 --overwrite --out=out --app-bundle-id=\"$npm_package_build_appId\" --name=\"$npm_package_build_productName\"",
    "nsis:win-x64": "electron-builder --x64 --win nsis",
    "dist:win-arm64": "electronite-packager . \"$npm_package_build_productName\" --platform=win32 --arch=arm64 --overwrite --out=out --app-bundle-id=\"$npm_package_build_appId\" --name=\"$npm_package_build_productName\"",
    "nsis:win-arm64": "electron-builder --arm64 --win nsis"
  },
  "dependencies": {},
  "devDependencies": {
    "electronite": "25.3.2-graphite",
    "electron": "25.3.2",
    "electronite-packager": "17.1.1-graphite",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "productName": "GatewayEdit",
    "appId": "com.example.gatewayedit",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "title": "GatewayEdit"
    }
  }
}
